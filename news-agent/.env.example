# Supabase connection (use service role key for server-side access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Anthropic API key for Claude enrichment
ANTHROPIC_API_KEY=sk-ant-...your-api-key

# Fetch interval in minutes (how often to check sources for new articles)
FETCH_INTERVAL_MIN=90

# Enrich interval in minutes (how often to process unprocessed articles with Claude)
ENRICH_INTERVAL_MIN=360

# Number of articles to enrich per batch
ENRICH_BATCH_SIZE=20

# Minimum relevance score (0-100) for an article to be published
RELEVANCE_THRESHOLD=20

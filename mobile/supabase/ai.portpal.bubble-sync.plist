    <integer>14400</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/vbot/Library/Logs/portpal-bubble-sync.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/vbot/Library/Logs/portpal-bubble-sync.error.log</string>

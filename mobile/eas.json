{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "22.12.0",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EAS_BUILD_INSTALL_FLAGS": "--legacy-peer-deps"
      }
    },
    "production": {
      "autoIncrement": true
    }
  }
}
